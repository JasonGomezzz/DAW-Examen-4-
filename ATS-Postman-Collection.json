{
  "info": {
    "name": "ATS - Sistema de Reclutamiento",
    "description": "Colección de pruebas para eureka-server, config-server, api-gateway, ms-usuarios, ms-vacantes y ms-postulaciones. Todas las peticiones de negocio pasan por el API Gateway (http://localhost:8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl", "value": "http://localhost:8080" },
    { "key": "eurekaUrl", "value": "http://localhost:8761" },
    { "key": "configUrl", "value": "http://localhost:8888" },
    { "key": "candidatoToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "usuarioCandidatoId", "value": "" },
    { "key": "usuarioAdminId", "value": "" },
    { "key": "vacanteId", "value": "" },
    { "key": "postulacionId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Infraestructura",
      "item": [
        {
          "name": "Eureka - Dashboard (los 6 servicios registrados)",
          "request": {
            "method": "GET",
            "url": "{{eurekaUrl}}/"
          }
        },
        {
          "name": "Config Server - Config de ms-usuarios",
          "request": {
            "method": "GET",
            "url": "{{configUrl}}/ms-usuarios/default"
          }
        },
        {
          "name": "API Gateway - Health",
          "request": {
            "method": "GET",
            "url": "{{gatewayUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "1. Usuarios",
      "item": [
        {
          "name": "Registrar candidato",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('usuarioCandidatoId', pm.response.json().id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayUrl}}/api/usuarios/registro",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"email\": \"juan.perez.postman@example.com\",\n  \"password\": \"candidato123\",\n  \"rol\": \"CANDIDATO\"\n}"
            }
          }
        },
        {
          "name": "Registrar admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('usuarioAdminId', pm.response.json().id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayUrl}}/api/usuarios/registro",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Maria Admin\",\n  \"email\": \"maria.admin.postman@example.com\",\n  \"password\": \"admin123\",\n  \"rol\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login candidato",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) { pm.collectionVariables.set('candidatoToken', pm.response.json().token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayUrl}}/api/usuarios/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez.postman@example.com\",\n  \"password\": \"candidato123\"\n}"
            }
          }
        },
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) { pm.collectionVariables.set('adminToken', pm.response.json().token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{gatewayUrl}}/api/usuarios/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria.admin.postman@example.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Obtener usuario por ID (autenticado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidatoToken}}" }],
            "url": "{{gatewayUrl}}/api/usuarios/{{usuarioCandidatoId}}"
          }
        },
        {
          "name": "Listar usuarios (solo ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{gatewayUrl}}/api/usuarios"
          }
        },
        {
          "name": "Listar usuarios sin token ADMIN (403 esperado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidatoToken}}" }],
            "url": "{{gatewayUrl}}/api/usuarios"
          }
        }
      ]
    },
    {
      "name": "2. Vacantes",
      "item": [
        {
          "name": "Listar vacantes abiertas (público)",
          "request": {
            "method": "GET",
            "url": "{{gatewayUrl}}/api/vacantes/abiertas"
          }
        },
        {
          "name": "Crear vacante (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('vacanteId', pm.response.json().id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/vacantes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Desarrollador Backend Java\",\n  \"descripcion\": \"Desarrollo de microservicios con Spring Boot\",\n  \"requisitos\": \"Java 21, Spring Boot, MySQL\",\n  \"salario\": 5500.00,\n  \"estado\": \"ABIERTA\"\n}"
            }
          }
        },
        {
          "name": "Crear vacante sin token ADMIN (403 esperado)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{candidatoToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/vacantes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"No debería crearse\",\n  \"descripcion\": \"Test\",\n  \"requisitos\": \"Test\",\n  \"salario\": 1000\n}"
            }
          }
        },
        {
          "name": "Obtener vacante por ID (autenticado)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidatoToken}}" }],
            "url": "{{gatewayUrl}}/api/vacantes/{{vacanteId}}"
          }
        },
        {
          "name": "Actualizar vacante (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/vacantes/{{vacanteId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Desarrollador Backend Java Senior\",\n  \"descripcion\": \"Desarrollo de microservicios con Spring Boot\",\n  \"requisitos\": \"Java 21, Spring Boot, MySQL, 4+ años\",\n  \"salario\": 6800.00,\n  \"estado\": \"ABIERTA\"\n}"
            }
          }
        },
        {
          "name": "Eliminar vacante (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{gatewayUrl}}/api/vacantes/{{vacanteId}}"
          }
        }
      ]
    },
    {
      "name": "3. Postulaciones",
      "item": [
        {
          "name": "Crear postulación (comunicación Feign con ms-usuarios y ms-vacantes)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('postulacionId', pm.response.json().id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{candidatoToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/postulaciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idVacante\": {{vacanteId}},\n  \"idUsuario\": {{usuarioCandidatoId}}\n}"
            }
          }
        },
        {
          "name": "Crear postulación con vacante inexistente (404 esperado)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{candidatoToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/postulaciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idVacante\": 999999,\n  \"idUsuario\": {{usuarioCandidatoId}}\n}"
            }
          }
        },
        {
          "name": "Actualizar estado de postulación (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/postulaciones/{{postulacionId}}/estado",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"EN_REVISION\"\n}"
            }
          }
        },
        {
          "name": "Historial de postulaciones por usuario",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{candidatoToken}}" }],
            "url": "{{gatewayUrl}}/api/postulaciones/usuario/{{usuarioCandidatoId}}"
          }
        },
        {
          "name": "[Circuit Breaker] Crear postulación con ms-vacantes apagado",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Antes de correr esta petición: detén el contenedor/proceso de ms-vacantes",
                  "// (docker stop ms-vacantes  o  cierra el proceso en IntelliJ)",
                  "// Ejecuta esta petición varias veces seguidas: las primeras reintentan (Retry)",
                  "// y fallan por timeout; tras superar el umbral de fallos el Circuit Breaker",
                  "// se abre y las siguientes responden inmediatamente con 503 y el mensaje",
                  "// 'No fue posible consultar el servicio. Intente nuevamente.'"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 503 (Service Unavailable) con ms-vacantes apagado', () => {",
                  "  pm.response.to.have.status(503);",
                  "});",
                  "pm.test('Mensaje de fallback presente', () => {",
                  "  pm.expect(pm.response.json().mensaje).to.include('No fue posible consultar el servicio');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{candidatoToken}}" }
            ],
            "url": "{{gatewayUrl}}/api/postulaciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idVacante\": {{vacanteId}},\n  \"idUsuario\": {{usuarioCandidatoId}}\n}"
            }
          }
        }
      ]
    }
  ]
}
